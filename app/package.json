{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "description": "Your personal AI assistant for managing day-to-day tasks, scheduling, and more. Powered by Cortex AI.",
  "author": "Mohit Sharma",
  "homepage": "https://github.com/mohitdixit02/cortex-os-assistant",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron:watch\" \"npm:dev:electron\"",
    "dev:web": "next dev",
    "dev:electron": "wait-on tcp:3000 file:dist-electron/main.js && cross-env ELECTRON_START_URL=http://localhost:3000 electron .",
    "dev:electron:watch": "tsc -p tsconfig.electron.json -w",
    "build": "next build && npm run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json",
    "start": "next start",
    "lint": "eslint",
    "start:electron": "npm run build:electron && cross-env ELECTRON_START_URL=http://localhost:3000 electron .",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "build": {
    "appId": "com.cortex-os-assistant.app",
    "productName": "Cortex OS Assistant",
    "publish": [
      {
        "provider": "github",
        "owner": "mohitdixit02",
        "repo": "cortex-os-assistant"
      }
    ],
    "releaseInfo": {
      "releaseNotesFile": "RELEASE_NOTES.md"
    },
    "files": [
      "dist-electron/**/*",
      "out/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "bin/${os}",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "public/assets/icon.ico",
      "artifactName": "Cortex-OS-Windows-Setup-${version}.${ext}"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/assets/icon.icns",
      "artifactName": "Cortex-OS-Mac-${version}.${ext}"
    },
    "linux": {
      "target": "AppImage",
      "icon": "public/assets/icon.png",
      "artifactName": "Cortex-OS-Linux-${version}.${ext}"
    }
  },
  "dependencies": {
    "@ericedouard/vad-node-realtime": "^0.2.0",
    "framer-motion": "^12.38.0",
    "next": "16.2.0",
    "next-auth": "^4.24.14",
    "node-audiorecorder": "^3.0.0",
    "pcm-player": "^0.0.18",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "react-timezone-select": "^3.3.3",
    "react-toastify": "^11.1.0",
    "swr": "^2.4.1"
  },
  "devDependencies": {
    "@types/electron": "^1.6.12",
    "@types/node": "^25.5.0",
    "@types/react": "19.2.14",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1",
    "electron-reloader": "^1.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.4"
  }
}
