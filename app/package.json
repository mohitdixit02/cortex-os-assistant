{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron:watch\" \"npm:dev:electron\"",
    "dev:web": "next dev",
    "dev:electron": "wait-on tcp:3000 file:dist-electron/main.js && cross-env ELECTRON_START_URL=http://localhost:3000 electron .",
    "dev:electron:watch": "tsc -p tsconfig.electron.json -w",
    "build": "next build && npm run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json",
    "start": "next start",
    "lint": "eslint",
    "start:electron": "npm run build:electron && cross-env ELECTRON_START_URL=http://localhost:3000 electron ."
  },
  "dependencies": {
    "@ericedouard/vad-node-realtime": "^0.2.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@types/three": "^0.184.0",
    "framer-motion": "^12.38.0",
    "next": "16.2.0",
    "node-audiorecorder": "^3.0.0",
    "pcm-player": "^0.0.18",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "sox-bin": "^1.1.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/electron": "^1.6.12",
    "@types/node": "^25.5.0",
    "@types/react": "19.2.14",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-reload": "^2.0.0-alpha.1",
    "electron-reloader": "^1.2.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.4"
  }
}
