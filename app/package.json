{
  "name": "app",
  "version": "0.1.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "dev:web": "next dev",
    "dev:electron": "wait-on tcp:3000 && cross-env ELECTRON_START_URL=http://localhost:3000 electron .",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "start:electron": "cross-env ELECTRON_START_URL=http://localhost:3000 electron ."
  },
  "dependencies": {
    "next": "16.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "eslint": "^9",
    "eslint-config-next": "16.2.0",
    "wait-on": "^9.0.4"
  }
}
