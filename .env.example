## Copy this file to .env and fill values before running docker-compose
# Postgres (container)
POSTGRES_USER=postgres
POSTGRES_DB=your_db_name
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Queue
CORTEX_QUEUE_PORT=8001

# Server
CORTEX_SERVER_PORT=8000

# Local Timezone - Event Worker Logging
TZ=Asia/Kolkata
